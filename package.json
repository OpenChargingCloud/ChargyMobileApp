{
  "name": "cloud.charging.open.apps.mobile",
  "displayName": "ChargyMobileApp",
  "version": "0.3.0",
  "description": "Transparenzsoftware für die Elektromobilität",
  "main": "index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "compile:ts": "tsc",
    "compile:sass": "sass src/scss/chargy.scss www/css/chargy.css",
    "bundle": "webpack --config webpack.config.cjs",
    "build": "cordova prepare browser",
    "browser": "cordova run browser",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run compile:ts && npm run compile:sass && npm run bundle && npm run test",
    "audit": "npm audit",
    "sbom": "cyclonedx-npm --package-lock-only --omit dev --output-reproducible --validate --output-file sbom.cdx.json",
    "sbom:all": "cyclonedx-npm --package-lock-only --ignore-npm-errors --output-reproducible --validate --output-file sbom.all.cdx.json"
  },
  "engines": {
    "node": ">=22.13 <27",
    "npm": ">=10"
  },
  "keywords": [
    "Chargy",
    "Transparenzsoftware",
    "Transparenz",
    "Eichrecht",
    "Elektromobilität",
    "E-Mobilität",
    "E-Mobility",
    "Ladestationen",
    "charging stations",
    "PTB"
  ],
  "author": "Achim Friedland <achim.friedland@graphdefined.com>",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@open-charging-cloud/chargy-core": "^0.9.1",
    "asn1.js": "^5.4.1",
    "base32-decode": "^1.0.0",
    "buffer": "^6.0.3",
    "chart.js": "^4.5.1",
    "decimal.js": "^10.6.0",
    "elliptic": "^6.6.1",
    "leaflet": "^1.9.4",
    "leaflet.awesome-markers": "^2.0.5",
    "moment": "^2.30.1",
    "pdfjs-dist": "^6.1.200"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^5.0.0",
    "@types/elliptic": "^6.4.18",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.awesome-markers": "^2.0.29",
    "@types/node": "^26.0.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "ajv-formats-draft2019": "^1.6.1",
    "chargy-clipboard": "file:cordova-plugins/chargy-clipboard",
    "cordova": "^13.0.0",
    "cordova-android": "^15.0.0",
    "cordova-browser": "^7.0.0",
    "cordova-ios": "^8.1.0",
    "cordova-plugin-android-permissions": "1.1.5",
    "cordova-plugin-app-version": "^0.1.14",
    "cordova-plugin-camera": "^8.0.0",
    "cordova-plugin-device": "^3.0.0",
    "cordova-plugin-dialogs": "^2.0.2",
    "cordova-plugin-file": "^8.1.3",
    "cordova-plugin-geolocation": "^5.0.0",
    "cordova-plugin-inappbrowser": "^7.0.0",
    "cordova-plugin-network-information": "^3.1.0",
    "minimizer-webpack-plugin": "^5.6.1",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "webpack": "^5.108.1",
    "webpack-cli": "^7.1.0"
  },
  "cordova": {
    "plugins": {
      "cordova-plugin-dialogs": {},
      "cordova-plugin-file": {
        "ANDROIDX_WEBKIT_VERSION": "1.4.0"
      },
      "cordova-plugin-device": {},
      "cordova-plugin-geolocation": {
        "GPS_REQUIRED": "true"
      },
      "cordova-plugin-app-version": {},
      "cordova-plugin-camera": {
        "ANDROIDX_CORE_VERSION": "1.6.+"
      },
      "cordova-plugin-network-information": {},
      "cordova-plugin-android-permissions": {},
      "cordova-plugin-inappbrowser": {},
      "chargy-clipboard": {}
    },
    "platforms": [
      "ios",
      "android",
      "browser"
    ]
  }
}
